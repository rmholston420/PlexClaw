# PlexClaw environment variables — copy to .env and fill in values.
# .env is gitignored; .env.example is committed.

# ── Cloud Claude (required for live cloud sessions) ──────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Local LLM override (Ollama / vLLM / LiteLLM) ─────────────────────────
# Uncomment and set to redirect all Claude SDK requests to your local backend.
# ANTHROPIC_BASE_URL=http://127.0.0.1:11434
# ANTHROPIC_AUTH_TOKEN=local

# ── Model aliases for local backends ─────────────────────────────────────
# PLEXCLAW_OLLAMA_MODEL=qwen3-coder:latest
# PLEXCLAW_VLLM_MODEL=Qwen/Qwen3-Coder-30B-A3B-Instruct

# ── PlexClaw server ───────────────────────────────────────────────────────
# PLEXCLAW_ALLOWED_ORIGINS=http://localhost:8020,http://127.0.0.1:8020
# PLEXCLAW_SESSION_IDLE_TIMEOUT_SECONDS=1800
# PLEXCLAW_SESSION_REAP_INTERVAL_SECONDS=60

# ── Local model URLs ──────────────────────────────────────────────────────
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# VLLM_BASE_URL=http://127.0.0.1:30000

# ── Recommended local Claude Code / Agent SDK settings ──────────────────────
# Point the SDK at Ollama's Anthropic-compatible endpoint when using local primary.
# Keep ANTHROPIC_API_KEY unset for fully local runs.
# ANTHROPIC_BASE_URL=http://127.0.0.1:11434
# ANTHROPIC_AUTH_TOKEN=local
#
# Prefer tool-capable coding models for PlexClaw local sessions.
# PLEXCLAW_OLLAMA_MODEL=qwen3-coder:latest
# PLEXCLAW_VLLM_MODEL=Qwen/Qwen3-Coder-30B-A3B-Instruct
#
# Note: weaker instruct models may emit prose that looks like tool output
# instead of valid structured tool events.

# ── Claude Code / Agent SDK project-local parity ─────────────────────
# These variables line up with .claude/settings.local.json for local/proxied runs.
# Claude Code and the Agent SDK both honor this Anthropic-compatible surface.

# ANTHROPIC_BASE_URL=http://127.0.0.1:11434
# ANTHROPIC_AUTH_TOKEN=local
# ANTHROPIC_DEFAULT_SONNET_MODEL=qwen3:latest
# ANTHROPIC_DEFAULT_OPUS_MODEL=qwen3:latest
# ANTHROPIC_DEFAULT_HAIKU_MODEL=qwen3:latest
# CLAUDE_CODE_SUBAGENT_MODEL=qwen3:latest
# API_TIMEOUT_MS=300000
# CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

# ── Local Claude-compatible alias mapping for CLI + SDK ─────────────────────
# Keep these aligned with .claude/settings.local.json when using a local primary.
# ANTHROPIC_DEFAULT_SONNET_MODEL=qwen3:latest
# ANTHROPIC_DEFAULT_OPUS_MODEL=qwen3:latest
# ANTHROPIC_DEFAULT_HAIKU_MODEL=qwen3:latest
# CLAUDE_CODE_SUBAGENT_MODEL=qwen3:latest

